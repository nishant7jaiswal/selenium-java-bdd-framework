<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium BDD Automation Suite"
       verbose="1"
       parallel="methods"
       thread-count="4"
       data-provider-thread-count="4">

    <listeners>
        <listener class-name="com.framework.utils.retry.RetryTransformer"/>
        <listener class-name="com.framework.utils.report.TestListener"/>
    </listeners>

    <test name="Regression Suite" preserve-order="true">
        <classes>
            <class name="com.framework.runners.TestRunner"/>
        </classes>
    </test>

</suite>
